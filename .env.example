TELEGRAM_BOT_TOKEN=your_bot_token_here
TIMEZONE=Europe/Moscow

# iCloud account #1 (your calendar)
ICLOUD1_APPLE_ID=you@example.com
ICLOUD1_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ICLOUD1_CALENDAR_NAME=Home

# iCloud account #2 (second calendar — required)
ICLOUD2_APPLE_ID=second@example.com
ICLOUD2_APP_PASSWORD=yyyy-yyyy-yyyy-yyyy
ICLOUD2_CALENDAR_NAME=Family
